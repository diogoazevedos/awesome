{
	"format_on_save": "off",
	"hard_tabs": true,
	"tab_size": 4,
	"preferred_line_length": 100,
	"wrap_guides": [100, 120],
	"show_whitespaces": "all",
	"colorize_brackets": true,
	"indent_guides": {
		"coloring": "indent_aware"
	},
	"file_finder": {
		"modal_max_width": "medium"
	},
	"inlay_hints": {
		"enabled": true
	},
	"diff_view_style": "unified",
	"git": {
		"inline_blame": {
			"show_commit_summary": true
		}
	},
	"calls": {
		"mute_on_join": true
	},
	"agent": {
		"default_model": {
			"provider": "copilot_chat",
			"model": "claude-sonnet-4.6",
			"enable_thinking": true,
			"effort": "high"
		},
		"inline_assistant_model": {
			"provider": "copilot_chat",
			"model": "gpt-5.3-codex"
		},
		"commit_message_model": {
			"provider": "copilot_chat",
			"model": "gpt-5-mini"
		},
		"thread_summary_model": {
			"provider": "copilot_chat",
			"model": "gpt-5-mini"
		},
		"inline_alternatives": [
			{
				"provider": "copilot_chat",
				"model": "claude-opus-4.6"
			}
		],
		"favorite_models": [
			{
				"provider": "copilot_chat",
				"model": "claude-sonnet-4.6"
			},
			{
				"provider": "copilot_chat",
				"model": "gpt-5.4"
			},
			{
				"provider": "copilot_chat",
				"model": "gemini-3.1-pro-preview"
			},
			{
				"provider": "copilot_chat",
				"model": "claude-opus-4.6"
			},
			{
				"provider": "copilot_chat",
				"model": "gpt-5-mini"
			}
		],
		"tool_permissions": {
			"tools": {
				"terminal": {
					"always_allow": [
						{ "pattern": "^cat\\b" },
						{ "pattern": "^ls\\b" },
						{ "pattern": "^head\\b" },
						{ "pattern": "^tail\\b" },
						{ "pattern": "^grep\\b" },
						{ "pattern": "^find\\b" },
						{ "pattern": "^diff\\b" },
						{ "pattern": "^echo\\b" },
						{ "pattern": "^sed\\s-n\\b" }
					]
				},
				"fetch": {
					"always_allow": [{ "pattern": "github\\.com" }]
				}
			}
		}
	},
	"agent_servers": {
		"claude-acp": {
			"type": "registry"
		}
	},
	"languages": {
		"TypeScript": {
			"inlay_hints": {
				"show_type_hints": false
			}
		}
	},
	"edit_predictions": {
		"provider": "copilot"
	},
	"theme": "Dracula",
	"base_keymap": "Atom",
	"buffer_font_family": "JetBrains Mono",
	"buffer_font_size": 13.0,
	"terminal": {
		"font_family": "Monaco",
		"minimum_contrast": 0.0
	},
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	}
}
